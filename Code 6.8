"""
Triple-Skip Residual Neural Network (TRNN) for OFDM Signal Modulation Classification
Based on: Zhang et al., IEEE Communications Letters, Vol. 25, No. 9, September 2021
"""

import os
import numpy as np
import torch
import torch.nn as nn
import torch.nn.functional as F
import torch.optim as optim
from torch.utils.data import Dataset, DataLoader
import matplotlib.pyplot as plt

# ══════════════════════════════════════════════════════════════════════════════
# 0.  CONSTANTS
# ══════════════════════════════════════════════════════════════════════════════

MODULATIONS = [
    "BPSK+BPSK", "BPSK+QPSK", "BPSK+8PSK",
    "QPSK+BPSK", "QPSK+QPSK", "QPSK+8PSK",
]
NUM_CLASSES     = len(MODULATIONS)
SAMPLING_LENGTH = 1024
N_SUBCARRIERS   = 64
CP_LENGTH       = 16

# ══════════════════════════════════════════════════════════════════════════════
# 1.  NETWORK
# ══════════════════════════════════════════════════════════════════════════════

def _conv_bn_relu(in_ch, out_ch, kernel, padding):
    return nn.Sequential(
        nn.Conv2d(in_ch, out_ch, kernel, padding=padding, bias=False),
        nn.BatchNorm2d(out_ch),
        nn.ReLU(inplace=True),
    )


class ResidualUnit(nn.Module):
    """Stack of num_conv conv(3×1) layers with a single skip connection."""
    def __init__(self, channels, num_conv):
        super().__init__()
        layers = []
        for _ in range(num_conv):
            layers.append(_conv_bn_relu(channels, channels,
                                        kernel=(3, 1), padding=(1, 0)))
        self.body = nn.Sequential(*layers)

    def forward(self, x):
        return x + self.body(x)


class TripleSkipResidualStack(nn.Module):
    """
    entry_conv(1×1) → RU-a(1 conv) → RU-b(2 conv) → RU-c(3 conv)
    with an outer lambda-skip from input to after the three RUs, then MaxPool.
    """
    def __init__(self, in_ch, out_ch, pool_size):
        super().__init__()
        self.entry = _conv_bn_relu(in_ch, out_ch, kernel=(1, 1), padding=(0, 0))
        self.ru_a  = ResidualUnit(out_ch, num_conv=1)
        self.ru_b  = ResidualUnit(out_ch, num_conv=2)
        self.ru_c  = ResidualUnit(out_ch, num_conv=3)
        self.proj  = (nn.Conv2d(in_ch, out_ch, kernel_size=(1, 1), bias=False)
                      if in_ch != out_ch else nn.Identity())
        self.pool  = nn.MaxPool2d(kernel_size=pool_size, stride=pool_size)

    def forward(self, x):
        skip = self.proj(x)
        out  = self.entry(x)
        out  = self.ru_a(out)
        out  = self.ru_b(out)
        out  = self.ru_c(out)
        if skip.shape[2:] != out.shape[2:]:
            skip = F.adaptive_avg_pool2d(skip, out.shape[2:])
        return self.pool(out + skip)


class TRNN(nn.Module):
    """
    Spatial layout through the 7 TRS blocks:
      Input              : (B, 1, 2, 1024)
      After TRS-1 (2,2)  : (B, 32, 1, 512)
      After TRS-2 (1,2)  : (B, 32, 1, 256)
      After TRS-3 (1,2)  : (B, 32, 1, 128)
      After TRS-4 (1,2)  : (B, 32, 1,  64)
      After TRS-5 (1,2)  : (B, 32, 1,  32)
      After TRS-6 (1,2)  : (B, 32, 1,  16)
      After TRS-7 (1,2)  : (B, 32, 1,   8)
      AdaptiveAvgPool    : (B, 32,  1,   1)
      Flatten + FC       : (B, 6)
    """
    _POOL_SIZES = [(2, 2)] + [(1, 2)] * 6

    def __init__(self, num_classes=NUM_CLASSES):
        super().__init__()
        blocks, in_ch = [], 1
        for pool_sz in self._POOL_SIZES:
            blocks.append(TripleSkipResidualStack(in_ch, 32, pool_sz))
            in_ch = 32
        self.trs        = nn.Sequential(*blocks)
        self.gap        = nn.AdaptiveAvgPool2d((1, 1))
        self.classifier = nn.Sequential(
            nn.Flatten(),
            nn.Linear(32, 128),
            nn.SiLU(),
            nn.Dropout(p=0.30),
            nn.Linear(128, num_classes),
        )

    def forward(self, x):
        if x.dim() == 3:
            x = x.unsqueeze(1)
        return self.classifier(self.gap(self.trs(x)))


# ══════════════════════════════════════════════════════════════════════════════
# 2.  SYNTHETIC DATASET
# ══════════════════════════════════════════════════════════════════════════════

def _bpsk(n): return (2 * np.random.randint(0, 2, n) - 1).astype(complex)
def _qpsk(n): return np.exp(1j * (np.pi/4 + np.random.randint(0, 4, n) * np.pi/2))
def _8psk(n): return np.exp(1j * np.random.randint(0, 8, n) * 2*np.pi/8)
_MODMAP = {"BPSK": _bpsk, "QPSK": _qpsk, "8PSK": _8psk}


def _ofdm_frame(mod, n_sub=N_SUBCARRIERS, cp=CP_LENGTH, n_sym=20):
    parts = []
    for _ in range(n_sym):
        td = np.fft.ifft(_MODMAP[mod](n_sub))
        parts.append(np.concatenate([td[-cp:], td]))
    return np.concatenate(parts)


def _rician_awgn(sig, snr_db, K=4.0, n_paths=3):
    los  = np.sqrt(K / (K + 1.0))
    scat = np.sqrt(1.0 / (K + 1.0)) / np.sqrt(max(n_paths - 1, 1))
    taps = [los + 0j] + [scat * (np.random.randn() + 1j*np.random.randn())
                          for _ in range(n_paths - 1)]
    rx = np.zeros(len(sig), dtype=complex)
    for d, tap in enumerate(taps):
        if d < len(sig):
            rx[d:] += tap * sig[:len(sig) - d]
    pwr       = np.mean(np.abs(rx) ** 2)
    noise_std = np.sqrt(pwr / (2.0 * 10 ** (snr_db / 10)))
    return rx + noise_std * (np.random.randn(len(rx)) + 1j*np.random.randn(len(rx)))


def generate_dataset(n_per_class=200, length=SAMPLING_LENGTH, snr_db=10.0):
    specs = [
        ("BPSK","BPSK"), ("BPSK","QPSK"), ("BPSK","8PSK"),
        ("QPSK","BPSK"), ("QPSK","QPSK"), ("QPSK","8PSK"),
    ]
    X_list, y_list = [], []
    for label, (hdr, pld) in enumerate(specs):
        print(f"  Class {label+1}/{NUM_CLASSES}: {MODULATIONS[label]} ...")
        for _ in range(n_per_class):
            raw = _ofdm_frame(pld)
            rx  = _rician_awgn(raw, snr_db)
            if len(rx) >= length:
                seg = rx[:length]
            else:
                seg = np.tile(rx, length // len(rx) + 1)[:length]
            seg = seg / (np.std(seg) + 1e-8)
            X_list.append(np.stack([seg.real, seg.imag]).astype(np.float32))
            y_list.append(label)
    X = np.array(X_list, dtype=np.float32)
    y = np.array(y_list, dtype=np.int64)
    perm = np.random.default_rng(0).permutation(len(y))
    return X[perm], y[perm]


def get_dataset(n_per_class, snr_db, cache_file="dataset_cache.npz"):
    """Load dataset from cache if it exists, otherwise generate and save it."""
    if os.path.exists(cache_file):
        print(f"Loading dataset from cache: {cache_file}")
        data = np.load(cache_file)
        return data["X"], data["y"]
    else:
        print("Generating new dataset ...")
        X, y = generate_dataset(n_per_class=n_per_class, snr_db=snr_db)
        np.savez(cache_file, X=X, y=y)
        print(f"Dataset saved to cache: {cache_file}")
        return X, y


class OFDMDataset(Dataset):
    def __init__(self, X, y):
        self.X = torch.from_numpy(X)
        self.y = torch.from_numpy(y)
    def __len__(self):        return len(self.y)
    def __getitem__(self, i): return self.X[i], self.y[i]


# ══════════════════════════════════════════════════════════════════════════════
# 3.  TRAINING
# ══════════════════════════════════════════════════════════════════════════════

def run_epoch(model, loader, criterion, optimizer, device):
    is_train = optimizer is not None
    model.train(is_train)
    total_loss, correct, total = 0.0, 0, 0
    ctx = torch.enable_grad() if is_train else torch.no_grad()
    with ctx:
        for xb, yb in loader:
            xb, yb  = xb.to(device), yb.to(device)
            logits   = model(xb)
            loss     = criterion(logits, yb)
            if is_train:
                optimizer.zero_grad()
                loss.backward()
                optimizer.step()
            total_loss += loss.item() * len(yb)
            correct    += (logits.argmax(1) == yb).sum().item()
            total      += len(yb)
    return total_loss / total, correct / total


def train(model, train_loader, val_loader,
          epochs=100, lr=1e-3, device="cpu", patience=10):
    model.to(device)
    criterion         = nn.CrossEntropyLoss()
    optimizer         = optim.Adam(model.parameters(), lr=lr)
    scheduler         = optim.lr_scheduler.CosineAnnealingLR(optimizer, T_max=epochs)
    best_acc          = 0.0
    best_state        = None
    epochs_no_improve = 0

    print(f"\n{'Epoch':>6} | {'Train Loss':>10} | {'Train Acc':>9} | "
          f"{'Val Loss':>8} | {'Val Acc':>8} | {'No Improve':>10}")
    print("─" * 68)

    for epoch in range(1, epochs + 1):
        tr_loss, tr_acc = run_epoch(model, train_loader, criterion, optimizer, device)
        vl_loss, vl_acc = run_epoch(model, val_loader,   criterion, None,      device)
        scheduler.step()

        if vl_acc > best_acc:
            best_acc          = vl_acc
            best_state        = {k: v.cpu().clone()
                                 for k, v in model.state_dict().items()}
            epochs_no_improve = 0
            flag = " ★"
        else:
            epochs_no_improve += 1
            flag = ""

        print(f"{epoch:>6} | {tr_loss:>10.4f} | {tr_acc:>8.2%} | "
              f"{vl_loss:>8.4f} | {vl_acc:>8.2%} | "
              f"{epochs_no_improve:>10}{flag}")

        if epochs_no_improve >= patience:
            print(f"\nEarly stopping at epoch {epoch} "
                  f"— no improvement for {patience} epochs.")
            break

    print(f"\nBest validation accuracy: {best_acc:.2%}")
    model.load_state_dict(best_state)
    return model


# ══════════════════════════════════════════════════════════════════════════════
# 4.  EVALUATION
# ══════════════════════════════════════════════════════════════════════════════

def evaluate(model, loader, device):
    counts = {m: [0, 0] for m in MODULATIONS}
    cm     = np.zeros((NUM_CLASSES, NUM_CLASSES), dtype=int)
    model.eval()
    with torch.no_grad():
        for xb, yb in loader:
            preds = model(xb.to(device)).argmax(1).cpu()
            for p, t in zip(preds.tolist(), yb.tolist()):
                counts[MODULATIONS[t]][1] += 1
                cm[t][p] += 1
                if p == t:
                    counts[MODULATIONS[t]][0] += 1

    print("\nPer-class accuracy:")
    print("─" * 38)
    for name, (c, t) in counts.items():
        acc = c / t
        bar = "█" * int(acc * 20)
        print(f"  {name:<14}: {acc:6.2%}  {bar}")

    print("\nConfusion matrix (rows=true, cols=predicted):")
    w = 14
    print(" " * w + "".join(f"{m:>{w}}" for m in MODULATIONS))
    print("─" * (w * (NUM_CLASSES + 1)))
    for i, row in enumerate(MODULATIONS):
        print(f"{row:<{w}}" + "".join(f"{cm[i,j]:>{w}}"
              for j in range(NUM_CLASSES)))


# ══════════════════════════════════════════════════════════════════════════════
# 5.  VISUALIZATIONS
# ══════════════════════════════════════════════════════════════════════════════

COLORS  = ["#e74c3c","#3498db","#2ecc71","#f39c12","#9b59b6","#1abc9c"]
MARKERS = ["o","s","^","D","v","P"]


def plot_iq_constellations(snr_db=10.0):
    fig, axes = plt.subplots(2, 3, figsize=(14, 9))
    fig.suptitle("I/Q Constellation Diagrams — All 6 Modulation Classes",
                 fontsize=14, fontweight="bold")
    specs = [
        ("BPSK","BPSK"), ("BPSK","QPSK"), ("BPSK","8PSK"),
        ("QPSK","BPSK"), ("QPSK","QPSK"), ("QPSK","8PSK"),
    ]
    for ax, (label, (hdr, pld)), color in zip(axes.flat, enumerate(specs), COLORS):
        raw = _ofdm_frame(pld, n_sym=40)
        rx  = _rician_awgn(raw, snr_db)
        seg = rx[:SAMPLING_LENGTH] / (np.std(rx[:SAMPLING_LENGTH]) + 1e-8)
        ax.scatter(seg.real, seg.imag, s=4, alpha=0.4, color=color, linewidths=0)
        ax.axhline(0, color="gray", linewidth=0.5, linestyle="--")
        ax.axvline(0, color="gray", linewidth=0.5, linestyle="--")
        ax.set_title(MODULATIONS[label], fontsize=11, fontweight="bold")
        ax.set_xlabel("In-phase (I)", fontsize=9)
        ax.set_ylabel("Quadrature (Q)", fontsize=9)
        ax.set_aspect("equal")
        ax.grid(True, alpha=0.3)
        lim = max(abs(seg.real).max(), abs(seg.imag).max()) * 1.1
        ax.set_xlim(-lim, lim)
        ax.set_ylim(-lim, lim)
    plt.tight_layout()
    plt.savefig("constellation_diagrams.png", dpi=150, bbox_inches="tight")
    plt.show()
    print("Saved → constellation_diagrams.png")


def plot_iq_time_signals(snr_db=10.0, n_samples=256):
    specs = [
        ("BPSK","BPSK"), ("BPSK","QPSK"), ("BPSK","8PSK"),
        ("QPSK","BPSK"), ("QPSK","QPSK"), ("QPSK","8PSK"),
    ]
    colors_q = ["#c0392b","#2980b9","#27ae60","#e67e22","#8e44ad","#16a085"]
    fig, axes = plt.subplots(6, 2, figsize=(14, 16), sharex=True)
    fig.suptitle("I/Q Time-Domain Signals — All 6 Modulation Classes",
                 fontsize=14, fontweight="bold")
    t = np.arange(n_samples)
    for row, ((hdr, pld), ci, cq) in enumerate(zip(specs, COLORS, colors_q)):
        raw = _ofdm_frame(pld)
        rx  = _rician_awgn(raw, snr_db)
        seg = rx[:n_samples] / (np.std(rx[:n_samples]) + 1e-8)
        axes[row, 0].plot(t, seg.real, color=ci, linewidth=0.8)
        axes[row, 0].set_ylabel(f"{MODULATIONS[row]}\nAmplitude", fontsize=8)
        axes[row, 0].set_title("In-phase (I)"   if row == 0 else "", fontsize=10)
        axes[row, 0].grid(True, alpha=0.3)
        axes[row, 0].set_ylim(-3.5, 3.5)
        axes[row, 1].plot(t, seg.imag, color=cq, linewidth=0.8)
        axes[row, 1].set_title("Quadrature (Q)" if row == 0 else "", fontsize=10)
        axes[row, 1].grid(True, alpha=0.3)
        axes[row, 1].set_ylim(-3.5, 3.5)
    axes[-1, 0].set_xlabel("Sample index", fontsize=10)
    axes[-1, 1].set_xlabel("Sample index", fontsize=10)
    plt.tight_layout()
    plt.savefig("iq_time_signals.png", dpi=150, bbox_inches="tight")
    plt.show()
    print("Saved → iq_time_signals.png")


def plot_power_spectrum(snr_db=10.0):
    specs = [
        ("BPSK","BPSK"), ("BPSK","QPSK"), ("BPSK","8PSK"),
        ("QPSK","BPSK"), ("QPSK","QPSK"), ("QPSK","8PSK"),
    ]
    fig, axes = plt.subplots(2, 3, figsize=(14, 8))
    fig.suptitle("Power Spectral Density — All 6 Modulation Classes",
                 fontsize=14, fontweight="bold")
    for ax, (label, (hdr, pld)), color in zip(axes.flat, enumerate(specs), COLORS):
        raw    = _ofdm_frame(pld, n_sym=40)
        rx     = _rician_awgn(raw, snr_db)
        seg    = rx[:SAMPLING_LENGTH]
        freqs  = np.fft.fftshift(np.fft.fftfreq(len(seg)))
        psd_db = 10 * np.log10(
                     np.fft.fftshift(np.abs(np.fft.fft(seg))**2) + 1e-12)
        ax.plot(freqs, psd_db, color=color, linewidth=0.8)
        ax.set_title(MODULATIONS[label], fontsize=10, fontweight="bold")
        ax.set_xlabel("Normalised Frequency", fontsize=8)
        ax.set_ylabel("Power (dB)", fontsize=8)
        ax.grid(True, alpha=0.3)
        ax.set_xlim(-0.5, 0.5)
    plt.tight_layout()
    plt.savefig("power_spectrum.png", dpi=150, bbox_inches="tight")
    plt.show()
    print("Saved → power_spectrum.png")


def plot_snr_sweep(model, device, snr_range=range(-10, 22, 2), n_per_class=100):
    acc_per_class = {name: [] for name in MODULATIONS}
    acc_overall   = []
    model.eval()
    print("\nRunning SNR sweep ...")
    for snr in snr_range:
        print(f"  SNR = {snr:+3d} dB ...", end="\r")
        X, y   = generate_dataset(n_per_class=n_per_class, snr_db=float(snr))
        loader = DataLoader(OFDMDataset(X, y), batch_size=64,
                            shuffle=False, num_workers=0)
        correct_per = {i: [0, 0] for i in range(NUM_CLASSES)}
        with torch.no_grad():
            for xb, yb in loader:
                preds = model(xb.to(device)).argmax(1).cpu()
                for p, t in zip(preds.tolist(), yb.tolist()):
                    correct_per[t][1] += 1
                    if p == t:
                        correct_per[t][0] += 1
        total_c = total_t = 0
        for i, name in enumerate(MODULATIONS):
            c, t = correct_per[i]
            acc_per_class[name].append(c / t)
            total_c += c
            total_t += t
        acc_overall.append(total_c / total_t)

    snr_list = list(snr_range)
    fig, (ax1, ax2) = plt.subplots(1, 2, figsize=(15, 6))
    fig.suptitle("TRNN Classification Accuracy vs SNR",
                 fontsize=14, fontweight="bold")
    for name, color, marker in zip(MODULATIONS, COLORS, MARKERS):
        ax1.plot(snr_list, acc_per_class[name], color=color, marker=marker,
                 linewidth=1.8, markersize=5, label=name)
    ax1.set_xlabel("SNR (dB)", fontsize=11)
    ax1.set_ylabel("Classification Accuracy", fontsize=11)
    ax1.set_title("Per-class Accuracy", fontsize=12)
    ax1.legend(fontsize=9, loc="lower right")
    ax1.grid(True, alpha=0.3)
    ax1.set_ylim(0, 1.05)
    ax1.yaxis.set_major_formatter(plt.FuncFormatter(lambda y, _: f"{y:.0%}"))
    ax2.plot(snr_list, acc_overall, color="#2c3e50", marker="o",
             linewidth=2.5, markersize=6)
    ax2.fill_between(snr_list, acc_overall, alpha=0.15, color="#2c3e50")
    ax2.set_xlabel("SNR (dB)", fontsize=11)
    ax2.set_ylabel("Classification Accuracy", fontsize=11)
    ax2.set_title("Overall Accuracy", fontsize=12)
    ax2.grid(True, alpha=0.3)
    ax2.set_ylim(0, 1.05)
    ax2.yaxis.set_major_formatter(plt.FuncFormatter(lambda y, _: f"{y:.0%}"))
    plt.tight_layout()
    plt.savefig("snr_accuracy_curve.png", dpi=150, bbox_inches="tight")
    plt.show()
    print("\nSaved → snr_accuracy_curve.png")


# ══════════════════════════════════════════════════════════════════════════════
# 6.  MAIN
# ══════════════════════════════════════════════════════════════════════════════

def main():
    # ── Hyper-parameters ──────────────────────────────────────────────────────
    SEED        = 42
    N_PER_CLASS = 4096
    SNR_DB      = 10.0
    BATCH_SIZE  = 64
    EPOCHS      = 100
    LR          = 1e-3
    PATIENCE    = 10
    SAVE_PATH   = "trnn_ofdm_best.pt"

    # ── Fix all random sources ────────────────────────────────────────────────
    np.random.seed(SEED)
    torch.manual_seed(SEED)
    torch.cuda.manual_seed_all(SEED)
    torch.backends.cudnn.deterministic = True
    torch.backends.cudnn.benchmark     = False

    device = "cuda" if torch.cuda.is_available() else "cpu"

    print("=" * 60)
    print("  TRNN — OFDM Modulation Classification")
    print("=" * 60)
    print(f"  Device   : {device}")
    print(f"  Samples  : {N_PER_CLASS}/class  |  SNR: {SNR_DB} dB")
    print(f"  Epochs   : up to {EPOCHS} (early stop patience={PATIENCE})")
    print(f"  Seed     : {SEED}  — results are reproducible")
    print("=" * 60)

    # ── Dataset (cached) ──────────────────────────────────────────────────────
    X, y         = get_dataset(N_PER_CLASS, SNR_DB)
    n_train      = int(0.7 * len(y))
    train_ds     = OFDMDataset(X[:n_train], y[:n_train])
    val_ds       = OFDMDataset(X[n_train:],  y[n_train:])
    train_loader = DataLoader(train_ds, BATCH_SIZE, shuffle=True,  num_workers=0)
    val_loader   = DataLoader(val_ds,   BATCH_SIZE, shuffle=False, num_workers=0)
    print(f"\n  Train: {len(train_ds)}  |  Val: {len(val_ds)}")

    # ── Model ─────────────────────────────────────────────────────────────────
    model    = TRNN()
    n_params = sum(p.numel() for p in model.parameters() if p.requires_grad)
    print(f"  TRNN parameters: {n_params:,}  (paper: ~189 K)")

    # ── Train ─────────────────────────────────────────────────────────────────
    model = train(model, train_loader, val_loader,
                  epochs=EPOCHS, lr=LR, device=device, patience=PATIENCE)

    # ── Evaluate ──────────────────────────────────────────────────────────────
    evaluate(model, val_loader, device)

    # ── Save ──────────────────────────────────────────────────────────────────
    torch.save({"model_state_dict": model.state_dict(),
                "modulations"     : MODULATIONS,
                "num_classes"     : NUM_CLASSES}, SAVE_PATH)
    print(f"\nModel saved → {SAVE_PATH}")

    # ── Plots ─────────────────────────────────────────────────────────────────
    print("\nGenerating plots ...")
    plot_iq_constellations(snr_db=SNR_DB)
    plot_iq_time_signals(snr_db=SNR_DB)
    plot_power_spectrum(snr_db=SNR_DB)
    plot_snr_sweep(model, device)


if __name__ == "__main__":
    main()
